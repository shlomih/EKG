    "@types/react": "~18.3.0",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.6.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.0.0",
    "react-test-renderer": "18.3.1",
    "jest-expo": "~52.0.0",
    "eslint": "^9.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@shopify/react-native-skia|@unimodules/.*|unimodules-.*|sentry-expo|native-base|react-native-svg)"
